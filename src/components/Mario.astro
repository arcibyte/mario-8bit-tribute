---
interface Props {
  size?: "small" | "medium" | "large";
  variant?: "classic" | "super" | "fire";
  isJumping?: boolean;
  isWalking?: boolean;
  className?: string;
}

const {
  size = "medium",
  variant = "classic",
  isJumping = false,
  isWalking = false,
  className = "",
} = Astro.props;

const sizeClasses = {
  small: "w-8 h-10",
  medium: "w-16 h-20",
  large: "w-24 h-32",
};

const variantColors = {
  classic: "bg-red-500",
  super: "bg-red-600",
  fire: "bg-orange-500",
};
---

<div
  class={`mario-sprite ${sizeClasses[size]} ${className} ${isJumping ? "mario-jump" : ""} ${isWalking ? "mario-walk" : ""}`}
>
  <div
    class={`mario-hat ${variantColors[variant]} w-full h-[22%] rounded-t-full relative z-20`}
  >
    <div
      class={`mario-brim ${variantColors[variant]} absolute -bottom-1 left-1/2 -translate-x-1/2 w-3/4 h-2 rounded-b-full border-t border-black/10`}
    >
    </div>
    <div
      class="mario-logo absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white w-3 h-3 rounded-full flex items-center justify-center"
    >
      <span class="text-[6px] font-black text-red-600 leading-none">M</span>
    </div>
    <div
      class="mario-hat-shine bg-white/70 w-1.5 h-1 rounded-full absolute top-0.5 left-1.5"
    >
    </div>
  </div>

  <div class="mario-face bg-orange-200 w-full h-4 relative">
    <div class="mario-eyes flex justify-between px-2 pt-1">
      <div class="mario-eye bg-black w-1 h-1 rounded-full"></div>
      <div class="mario-eye bg-black w-1 h-1 rounded-full"></div>
    </div>

    <div class="mario-mustache bg-black w-4 h-1 rounded-full mx-auto mt-1">
    </div>
  </div>

  <div class={`mario-shirt ${variantColors[variant]} w-full h-5 relative`}>
    <div class="mario-buttons flex justify-center space-x-1 pt-1">
      <div class="mario-button bg-yellow-400 w-1 h-1 rounded-full"></div>
      <div class="mario-button bg-yellow-400 w-1 h-1 rounded-full"></div>
    </div>

    <div class="mario-suspenders">
      <div class="mario-suspender bg-blue-600 w-1 h-full absolute left-1 top-0">
      </div>
      <div
        class="mario-suspender bg-blue-600 w-1 h-full absolute right-1 top-0"
      >
      </div>
    </div>
  </div>

  <div class="mario-overalls bg-blue-600 w-full h-4 rounded-b-lg"></div>
</div>

<div class="bg-black w-1.5 h-full rounded-b-sm"></div>
<div class="bg-black w-1.5 h-full rounded-b-sm"></div>

<div class="mario-face bg-orange-200 w-full h-[20%] relative z-20 rounded-sm">
</div>
