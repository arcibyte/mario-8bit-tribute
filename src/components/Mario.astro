---
interface Props {
  size?: "small" | "medium" | "large";
  variant?: "classic" | "super" | "fire";
  isJumping?: boolean;
  isWalking?: boolean;
  className?: string;
}

const {
  size = "medium",
  variant = "classic",
  isJumping = false,
  isWalking = false,
  className = "",
} = Astro.props;

// Proporciones ajustadas para mantener el aspecto de bloque (4:5 aprox)
const sizeClasses = {
  small: "w-8 h-10",
  medium: "w-16 h-20",
  large: "w-24 h-32",
};

// Paleta hexadecimal exacta de Super Mario Bros (NES)
const variantColors = {
  classic: {
    top: "bg-[#d82800]",
    overalls: "bg-[#0058f8]",
    accent: "bg-[#f8b800]",
    skin: "bg-[#f8d8b0]",
  },
  super: {
    top: "bg-[#d82800]",
    overalls: "bg-[#0058f8]",
    accent: "bg-[#f8b800]",
    skin: "bg-[#f8d8b0]",
  },
  fire: {
    top: "bg-[#ffffff]",
    overalls: "bg-[#d82800]",
    accent: "bg-[#0058f8]",
    skin: "bg-[#f8d8b0]",
  },
};

const colors = variantColors[variant];
---

<div
  class={`mario-sprite relative ${sizeClasses[size]} ${className} ${isJumping ? "mario-jump" : ""} ${isWalking ? "mario-walk" : ""}`}
>
  <div class="mario-hat w-full h-[25%] relative z-20">
    <div class={`${colors.top} w-[60%] h-[70%] absolute bottom-0 left-[20%]`}>
    </div>
    <div class={`${colors.top} w-[60%] h-[30%] absolute bottom-0 right-0`}>
    </div>
  </div>

  <div class="mario-head w-[90%] h-[25%] mx-auto flex relative z-10">
    <div class="w-[30%] h-[80%] bg-[#000] absolute top-[10%] left-0"></div>

    <div class={`${colors.skin} w-[60%] h-full absolute left-[30%]`}>
      <div class="w-[15%] h-[40%] bg-[#000] absolute right-[20%] top-[15%]">
      </div>
      <div
        class="w-[50%] h-[25%] bg-[#000] absolute right-[-20%] bottom-[20%] z-20"
      >
      </div>
      <div
        class={`${colors.skin} w-[30%] h-[35%] absolute right-[-30%] top-[25%] z-10 shadow-[-2px_2px_0_rgba(0,0,0,0.15)]`}
      >
      </div>
    </div>
  </div>

  <div class="mario-body w-full h-[35%] relative z-20">
    <div class={`${colors.top} w-[70%] h-[60%] mx-auto relative`}>
      <div class={`${colors.overalls} w-[20%] h-full absolute left-[15%]`}>
      </div>
      <div class={`${colors.overalls} w-[20%] h-full absolute right-[15%]`}>
      </div>
    </div>

    <div
      class={`${colors.overalls} w-[70%] h-[40%] mx-auto relative flex justify-center space-x-2 pt-1`}
    >
      <div class={`${colors.accent} w-[15%] h-[40%]`}></div>
      <div class={`${colors.accent} w-[15%] h-[40%]`}></div>
    </div>

    <div
      class="w-[20%] h-[40%] bg-white absolute left-0 top-[20%] shadow-[2px_2px_0_rgba(0,0,0,0.1)]"
    >
    </div>
    <div
      class="w-[20%] h-[40%] bg-white absolute right-0 top-[20%] shadow-[-2px_2px_0_rgba(0,0,0,0.1)]"
    >
    </div>
  </div>

  <div
    class="mario-legs w-[70%] h-[15%] mx-auto flex justify-between relative z-10"
  >
    <div class="mario-shoe bg-[#000] w-[35%] h-full"></div>
    <div class="mario-shoe bg-[#000] w-[35%] h-full"></div>
  </div>
</div>

<style>
  .mario-sprite {
    image-rendering: pixelated;
  }

  /* Animaciones estilo NES (sin fluidez, por cuadros de animación) */
  .mario-jump {
    animation: mario-jump-anim 0.4s steps(1) infinite;
  }

  .mario-walk {
    animation: mario-walk-bounce 0.3s steps(2) infinite;
  }

  .mario-walk .mario-shoe:nth-child(1) {
    animation: mario-step-left 0.3s steps(1) infinite;
  }

  .mario-walk .mario-shoe:nth-child(2) {
    animation: mario-step-right 0.3s steps(1) infinite;
  }

  @keyframes mario-jump-anim {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-25%);
    }
  }

  @keyframes mario-walk-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-5%);
    }
  }

  /* Los pies ya no rotan, se desplazan verticalmente como los verdaderos sprites */
  @keyframes mario-step-left {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-40%);
    }
  }

  @keyframes mario-step-right {
    0%,
    100% {
      transform: translateY(-40%);
    }
    50% {
      transform: translateY(0);
    }
  }
</style>
