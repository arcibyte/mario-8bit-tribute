---
interface Props {
  size?: "small" | "medium" | "large";
  variant?: "classic" | "super" | "fire";
  isJumping?: boolean;
  isWalking?: boolean;
  className?: string;
}

const {
  size = "medium",
  variant = "classic",
  isJumping = false,
  isWalking = false,
  className = "",
} = Astro.props;

const sizeClasses = {
  small: "w-8 h-10",
  medium: "w-16 h-20",
  large: "w-24 h-32",
};

const variantColors = {
  classic: { top: "bg-red-600", overalls: "bg-blue-700", accent: "bg-red-600" },
  super: {
    top: "bg-red-700",
    overalls: "bg-blue-800",
    accent: "bg-yellow-400",
  },
  fire: { top: "bg-white", overalls: "bg-red-600", accent: "bg-white" },
};

const colors = variantColors[variant];
---

<div
  class={`mario-sprite relative ${sizeClasses[size]} ${className} ${isJumping ? "mario-jump" : ""} ${isWalking ? "mario-walk" : ""}`}
>
  <div
    class={`mario-hat ${colors.top} w-full h-[22%] rounded-t-full relative z-20`}
  >
    <div
      class={`mario-brim ${colors.top} absolute -bottom-1 left-1/2 -translate-x-1/2 w-3/4 h-2 rounded-b-full border-t border-black/10`}
    >
    </div>
    <!-- M logo -->
    <div
      class="mario-logo absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white w-3 h-3 rounded-full flex items-center justify-center"
    >
      <span class="text-[6px] font-black text-red-600 leading-none">M</span>
    </div>
    <div
      class="mario-hat-shine bg-white/70 w-1.5 h-1 rounded-full absolute top-0.5 left-1.5"
    >
    </div>
  </div>

  <div
    class="mario-hair absolute top-[18%] left-0 w-full h-[10%] z-10 flex justify-between px-0.5"
  >
    <div class="bg-black w-1.5 h-full rounded-b-sm"></div>
    <div class="bg-black w-1.5 h-full rounded-b-sm"></div>
  </div>

  <!-- face -->
  <div class="mario-face bg-orange-200 w-full h-[20%] relative z-20 rounded-sm">
    <div class="mario-eyes flex justify-between px-2.5 pt-1.5">
      <div class="mario-eye bg-black w-1 h-1.5 rounded-full"></div>
      <div class="mario-eye bg-black w-1 h-1.5 rounded-full"></div>
    </div>

    <div
      class="mario-nose bg-orange-300 w-2.5 h-1.5 rounded-full mx-auto mt-0.5"
    >
    </div>

    <!-- Mustache -->
    <div
      class="mario-mustache bg-black w-5 h-1.5 rounded-b-full mx-auto -mt-0.5 relative z-20"
    >
    </div>
  </div>

  <div
    class={`mario-shirt ${colors.top} w-full h-[16%] relative z-10 flex justify-between items-center`}
  >
    <div
      class="mario-glove bg-white w-2 h-2 rounded-full absolute -left-1 top-1/2 -translate-y-1/2 border border-black/10"
    >
    </div>

    <div
      class="mario-glove bg-white w-2 h-2 rounded-full absolute -right-1 top-1/2 -translate-y-1/2 border border-black/10"
    >
    </div>

    <!-- Overall straps -->
    <div
      class={`mario-suspender ${colors.overalls} w-1.5 h-full absolute left-2`}
    >
    </div>
    <div
      class={`mario-suspender ${colors.overalls} w-1.5 h-full absolute right-2`}
    >
    </div>
  </div>

  <!-- overalls with buttons -->
  <div
    class={`mario-overalls ${colors.overalls} w-full h-[20%] relative z-20 rounded-t-sm`}
  >
    <div class="mario-buttons flex justify-center space-x-3 pt-1">
      <div
        class={`mario-button ${colors.accent} w-1.5 h-1.5 rounded-full border border-black/20`}
      >
      </div>
      <div
        class={`mario-button ${colors.accent} w-1.5 h-1.5 rounded-full border border-black/20`}
      >
      </div>
    </div>
  </div>

  <!-- Legs / shoes -->
  <div
    class="mario-legs w-full h-[12%] flex justify-between px-1 relative z-10"
  >
    <div
      class="mario-shoe bg-amber-800 w-[45%] h-full rounded-b-full border border-black/20"
    >
    </div>
    <div
      class="mario-shoe bg-amber-800 w-[45%] h-full rounded-b-full border border-black/20"
    >
    </div>
  </div>
</div>

<style>
  .mario-jump {
    animation: mario-jump-anim 0.6s ease-in-out infinite;
  }

  .mario-walk .mario-legs .mario-shoe:nth-child(1) {
    animation: mario-step-left 0.4s ease-in-out infinite;
  }
  .mario-walk .mario-legs .mario-shoe:nth-child(2) {
    animation: mario-step-right 0.4s ease-in-out infinite;
  }

  @keyframes mario-jump-anim {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-25%);
    }
  }

  @keyframes mario-step-left {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-10%) rotate(-8deg);
    }
  }

  @keyframes mario-step-right {
    0%,
    100% {
      transform: translateY(-10%) rotate(8deg);
    }
    50% {
      transform: translateY(0) rotate(0deg);
    }
  }
</style>
