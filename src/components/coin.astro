---
interface Props {
  size?: "small" | "medium" | "large";
  isCollected?: boolean;
  className?: string;
  position?: "ground" | "floating" | "high" | "underground";
  x?: number; // horizontal offset in the world
  y?: number; // custom vertical offset
}

const {
  size = "medium",
  isCollected = false,
  className = "",
  position = "ground",
  x = 0,
  y = 0,
} = Astro.props;

const sizeClasses = {
  small: "w-4 h-6",
  medium: "w-6 h-8",
  large: "w-10 h-14",
};

const positionClasses = {
  ground: "mario-ground-level",
  floating: "mario-floating-level",
  high: "mario-high-level",
  underground: "mario-underground-level",
};

const customStyle =
  x !== 0 || y !== 0 ? { transform: `translate(${x}px, ${y}px)` } : {};
---

<div
  class={`game-element ${sizeClasses[size]} ${positionClasses[position]} ${className} ${isCollected ? "element-collected" : ""}`}
  style={customStyle}
>
  <div class="mario-coin w-full h-full relative">
    <div class="absolute inset-y-0 left-[15%] right-[15%] bg-[#000000]"></div>
    <div class="absolute inset-x-0 top-[15%] bottom-[15%] bg-[#000000]"></div>

    <div class="absolute inset-y-[15%] left-[15%] right-[15%] bg-[#f8b800]">
    </div>
    <div class="absolute inset-x-[15%] top-[15%] bottom-[15%] bg-[#f8b800]">
    </div>

    <div
      class="absolute left-[25%] top-[20%] bottom-[20%] w-[15%] bg-[#ffffff]"
    >
    </div>

    <div
      class="absolute right-[25%] top-[20%] bottom-[20%] w-[15%] bg-[#f87800]"
    >
    </div>
    <div
      class="absolute left-[35%] right-[35%] bottom-[25%] h-[15%] bg-[#f87800]"
    >
    </div>
  </div>
</div>

<style>
  .game-element {
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    image-rendering: crisp-edges;
    position: absolute;
    display: inline-block;
    z-index: 10;
  }

  .mario-coin {
    animation: coin-spin 0.6s steps(3, end) infinite;
  }

  @keyframes coin-spin {
    0% {
      transform: scaleX(1);
    }
    50% {
      /* Comprime la moneda horizontalmente para simular que gira de perfil */
      transform: scaleX(0.1);
    }
    100% {
      transform: scaleX(1);
    }
  }

  .mario-ground-level {
    bottom: 300px;
  }

  .mario-floating-level {
    bottom: 350px;
  }

  .mario-high-level {
    bottom: 390px;
  }

  .mario-underground-level {
    bottom: 90px;
  }

  .element-collected {
    opacity: 0;
    visibility: hidden;
  }

  @media (max-width: 768px) {
    .mario-ground-level {
      bottom: 80px;
    }

    .mario-floating-level {
      bottom: 140px;
    }

    .mario-high-level {
      bottom: 200px;
    }

    .mario-underground-level {
      bottom: 60px;
    }
  }
</style>
