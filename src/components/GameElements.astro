---
interface Props {
  element?: 'coin' | 'block' | 'mushroom' | 'flower' | 'star' | 'flag';
  size?: 'small' | 'medium' | 'large';
  isCollected?: boolean;
  className?: string;
  position?: 'ground' | 'floating' | 'high' | 'underground';
  x?: number; // horizontal offset in the world
  y?: number; // custom vertical offset
}

const { 
  element = 'block',
  size = 'medium',
  isCollected = false,
  className = '',
  position = 'ground',
  x = 0,
  y = 0
} = Astro.props;

const sizeClasses = {
  small: 'w-6 h-6',
  medium: 'w-8 h-8',
  large: 'w-12 h-12'
};

const positionClasses = {
  ground: 'mario-ground-level',
  floating: 'mario-floating-level',
  high: 'mario-high-level',
  underground: 'mario-underground-level'
};

const customStyle = (x !== 0 || y !== 0) ? { transform: `translate(${x}px, ${y}px)` } : {};
---

<div 
  class={`game-element ${sizeClasses[size]} ${positionClasses[position]} ${className} ${isCollected ? 'element-collected' : ''}`}
  style={customStyle}
>

  {element === 'coin' && (
    <div class="mario-coin bg-yellow-400 w-full h-full rounded-full border-2 border-black relative flex items-center justify-center">
      <div class="coin-inner bg-yellow-500 w-2/3 h-2/3 rounded-full flex items-center justify-center">
        <span class="coin-symbol text-yellow-900 font-black text-xs leading-none">¢</span>
      </div>
    </div>
  )}
  
  {element === 'block' && (
    <div class="mario-block bg-amber-600 w-full h-full border-2 border-black relative flex items-center justify-center">
      <span class="block-mark text-amber-100 font-black text-base leading-none">?</span>
      <div class="block-corner bg-amber-800 w-1 h-1 absolute top-0.5 left-0.5"></div>
      <div class="block-corner bg-amber-800 w-1 h-1 absolute top-0.5 right-0.5"></div>
      <div class="block-corner bg-amber-800 w-1 h-1 absolute bottom-0.5 left-0.5"></div>
      <div class="block-corner bg-amber-800 w-1 h-1 absolute bottom-0.5 right-0.5"></div>
    </div>
  )}
  
  {element === 'mushroom' && (
    <div class="mario-mushroom w-full h-full relative flex flex-col items-center">
      <!-- Mushroom cap -->
      <div class="mushroom-head bg-red-600 w-full h-3/5 rounded-t-full border-2 border-black relative">
        <div class="mushroom-spots flex justify-center gap-1.5 pt-1">
          <div class="mushroom-spot bg-white w-1.5 h-1.5 rounded-full border border-black"></div>
          <div class="mushroom-spot bg-white w-1.5 h-1.5 rounded-full border border-black"></div>
        </div>
      </div>
      <!-- Mushroom stem -->
      <div class="mushroom-stem bg-orange-100 w-3/5 h-2/5 border-2 border-t-0 border-black"></div>
    </div>
  )}
  
  {element === 'flower' && (
    <div class="mario-flower w-full h-full relative flex flex-col items-center justify-end">
      <!-- Fire flower -->
      <div class="flower-petals bg-white w-full h-3/5 rounded-full border-2 border-black relative flex items-center justify-center">
        <div class="flower-center bg-red-600 w-2/5 h-2/5 rounded-full border border-black"></div>
        <div class="flame bg-orange-500 w-2 h-2.5 absolute -top-1.5 left-0.5 rounded-t-full border border-black"></div>
        <div class="flame bg-orange-500 w-2 h-2.5 absolute -top-1.5 right-0.5 rounded-t-full border border-black"></div>
      </div>
      <!-- Stem -->
      <div class="flower-stem bg-green-600 w-1.5 h-1/4 border border-black"></div>
    </div>
  )}
  
  {element === 'star' && (
    <div class="mario-star w-full h-full relative flex items-center justify-center">
      <span class="star-shape text-yellow-400 text-2xl leading-none" style="-webkit-text-stroke: 1.5px black;">★</span>
    </div>
  )}
  
  {element === 'flag' && (
    <div class="mario-flag w-full h-full relative">
      <!-- Pole -->
      <div class="flag-pole bg-gray-300 w-1 h-full absolute left-0 border border-black"></div>
      <!-- Banner -->
      <div class="flag-banner bg-green-600 w-3/4 h-1/2 absolute top-0 left-1 border border-black"></div>
    </div>
  )}
  
</div>

<style>
  .game-element {
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    image-rendering: crisp-edges;
    position: absolute;
    display: inline-block;
    z-index: 10;
  }

  .mario-ground-level {
    bottom: 250px; 
  }

  .mario-floating-level {
    bottom: 310px;
  }

  .mario-high-level {
    bottom: 390px;
  }

  .mario-underground-level {
    bottom: 90px; 
  }

  .element-collected {
    opacity: 0;
    visibility: hidden;
  }

  @media (max-width: 768px) {
    .mario-ground-level {
      bottom: 110px;
    }
    
    .mario-floating-level {
      bottom: 170px;
    }
    
    .mario-high-level {
      bottom: 230px;
    }

    .mario-underground-level {
      bottom: 40px;
    }
  }
</style>