---
interface Props {
  element?: "coin" | "block" | "mushroom" | "flower" | "star" | "flag";
  size?: "small" | "medium" | "large";
  isCollected?: boolean;
  className?: string;
  position?: "ground" | "floating" | "high" | "underground";
  x?: number; // horizontal offset in the world
  y?: number; // custom vertical offset
}

const {
  element = "block",
  size = "medium",
  isCollected = false,
  className = "",
  position = "ground",
  x = 0,
  y = 0,
} = Astro.props;

// Proporciones estandarizadas para grillas de 16x16
const sizeClasses = {
  small: "w-6 h-6",
  medium: "w-8 h-8",
  large: "w-12 h-12",
};

const positionClasses = {
  ground: "mario-ground-level",
  floating: "mario-floating-level",
  high: "mario-high-level",
  underground: "mario-underground-level",
};

const customStyle =
  x !== 0 || y !== 0 ? { transform: `translate(${x}px, ${y}px)` } : {};
---

<div
  class={`game-element ${sizeClasses[size]} ${positionClasses[position]} ${className} ${isCollected ? "element-collected" : ""}`}
  style={customStyle}
>
  {
    element === "coin" && (
      <div class="mario-coin w-full h-full relative">
        <div class="absolute inset-y-0 left-[15%] right-[15%] bg-[#000000]" />
        <div class="absolute inset-x-0 top-[15%] bottom-[15%] bg-[#000000]" />
        <div class="absolute inset-y-[15%] left-[15%] right-[15%] bg-[#f8b800]" />
        <div class="absolute inset-x-[15%] top-[15%] bottom-[15%] bg-[#f8b800]" />
        <div class="absolute left-[25%] top-[20%] bottom-[20%] w-[15%] bg-[#ffffff]" />
        <div class="absolute right-[25%] top-[20%] bottom-[20%] w-[15%] bg-[#f87800]" />
        <div class="absolute left-[35%] right-[35%] bottom-[25%] h-[15%] bg-[#f87800]" />
      </div>
    )
  }

  {
    element === "block" && (
      <div class="mario-block bg-[#f87800] w-full h-full border-[2px] border-black relative flex items-center justify-center overflow-hidden">
        <div class="absolute top-[2px] left-[2px] w-[2px] h-[2px] bg-black" />
        <div class="absolute top-[2px] right-[2px] w-[2px] h-[2px] bg-black" />
        <div class="absolute bottom-[2px] left-[2px] w-[2px] h-[2px] bg-black" />
        <div class="absolute bottom-[2px] right-[2px] w-[2px] h-[2px] bg-black" />
        <span
          class="block-mark text-[#f8b800] text-xl drop-shadow-[2px_2px_0_rgba(0,0,0,1)]"
          style="font-family: 'Silkscreen', monospace;"
        >
          ?
        </span>
      </div>
    )
  }

  {
    element === "mushroom" && (
      <div class="mario-mushroom w-full h-full relative flex flex-col items-center">
        <div class="w-[90%] h-[60%] bg-[#d82800] relative border-[2px] border-black border-b-0 flex justify-center">
          <div class="absolute top-[10%] left-[10%] w-[25%] h-[40%] bg-white border-[2px] border-black" />
          <div class="absolute top-[10%] right-[10%] w-[25%] h-[40%] bg-white border-[2px] border-black" />
          <div class="absolute top-[40%] w-[35%] h-[40%] bg-white border-[2px] border-black" />
        </div>
        <div class="w-[60%] h-[40%] bg-[#f8d870] border-[2px] border-black relative flex justify-center gap-[10%] pt-1">
          <div class="w-[15%] h-[40%] bg-black" />
          <div class="w-[15%] h-[40%] bg-black" />
        </div>
      </div>
    )
  }

  {
    element === "flower" && (
      <div class="mario-flower w-full h-full relative flex flex-col items-center justify-end">
        <div class="w-[70%] h-[50%] bg-[#f87800] border-[2px] border-black flex items-center justify-center relative z-10">
          <div class="w-[60%] h-[60%] bg-[#ffffff] border-[2px] border-black flex items-center justify-center">
            <div class="w-[40%] h-[40%] bg-[#000000]" />
          </div>
        </div>
        <div class="w-[20%] h-[50%] bg-[#00a800] border-[2px] border-black relative">
          <div class="absolute top-[20%] right-[100%] w-[150%] h-[30%] bg-[#00a800] border-[2px] border-black border-r-0" />
          <div class="absolute top-[50%] left-[100%] w-[150%] h-[30%] bg-[#00a800] border-[2px] border-black border-l-0" />
        </div>
      </div>
    )
  }

  {
    element === "star" && (
      <div class="mario-star w-full h-full relative flex items-center justify-center">
        <div class="absolute w-[40%] h-[90%] bg-[#f8b800] border-x-[2px] border-black" />
        <div class="absolute w-[90%] h-[40%] bg-[#f8b800] border-y-[2px] border-black" />
        <div class="absolute w-[70%] h-[70%] bg-[#f8b800] border-[2px] border-black" />
        <div class="absolute flex gap-[4px] z-10 mt-[10%]">
          <div class="w-[3px] h-[8px] bg-black" />
          <div class="w-[3px] h-[8px] bg-black" />
        </div>
      </div>
    )
  }

  {
    element === "flag" && (
      <div class="mario-flag w-full h-full relative flex">
        <div class="w-[15%] h-full bg-[#00a800] border-[2px] border-black relative z-10 ml-[20%]">
          <div class="absolute -top-[15%] -left-[100%] w-[300%] h-[15%] bg-[#00a800] border-[2px] border-black" />
        </div>
        <div class="w-[60%] h-[40%] bg-[#00a800] border-[2px] border-black border-l-0 mt-[20%]" />
      </div>
    )
  }
</div>

<style>
  .game-element {
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    image-rendering: crisp-edges;
    position: absolute;
    display: inline-block;
    z-index: 10;
  }

  .mario-ground-level {
    bottom: 250px;
  }

  .mario-floating-level {
    bottom: 310px;
  }

  .mario-high-level {
    bottom: 390px;
  }

  .mario-underground-level {
    bottom: 90px;
  }

  .element-collected {
    opacity: 0;
    visibility: hidden;
  }

  @media (max-width: 768px) {
    .mario-ground-level {
      bottom: 110px;
    }
    .mario-floating-level {
      bottom: 170px;
    }
    .mario-high-level {
      bottom: 230px;
    }
    .mario-underground-level {
      bottom: 40px;
    }
  }
</style>
