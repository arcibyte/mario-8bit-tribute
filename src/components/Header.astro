---
interface Props {
  score?: number;
  coins?: number;
  world?: string;
  lives?: number;
  time?: number;
}

const {
  score = 999999,
  coins = 999,
  world = "1-1",
  lives = 3,
  time = 400,
} = Astro.props;
---

<header
  class="bg-black text-white p-4 border-b-4 border-[#f8b800] sticky top-0 z-50"
>
  <div class="max-w-7xl mx-auto">
    <div class="md:hidden">
      <div class="flex justify-between items-center mb-4">
        <h1 class="text-xl font-pixel font-bold text-[#f8b800] pixel-text">
          SUPER MARIO
        </h1>
        <button
          id="menu-toggle"
          class="text-white hover:text-[#f8b800] focus:outline-none"
        >
          <svg
            class="w-6 h-6 image-render-pixel"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="square"
              stroke-linejoin="miter"
              stroke-width="3"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>

      <div
        class="grid grid-cols-2 gap-2 text-sm font-pixel bg-[#111] p-2 border-2 border-white"
      >
        <div class="flex items-center space-x-2">
          <div class="coin-small"></div>
          <span class="text-[#f8b800]">×{coins}</span>
        </div>
        <div class="text-[#d82800]">SC: {score}</div>
        <div class="text-[#00a800]">W: {world}</div>
        <div class="text-[#3cbcfc]">LIVES: {lives}</div>
      </div>
    </div>

    <div class="hidden md:flex justify-between items-center">
      <div class="flex items-center space-x-4">
        <h1
          class="text-3xl font-pixel font-bold text-[#f8b800] pixel-text tracking-wider animate-pulse"
        >
          SUPER MARIO
        </h1>
      </div>

      <nav class="hidden lg:flex items-center space-x-2 font-pixel">
        <a href="/" class="nav-link">HOME</a>
        <a href="/gallery" class="nav-link">GALLERY</a>
        <a href="/timeline" class="nav-link">TIMELINE</a>
        <a href="/sounds" class="nav-link">SOUNDS</a>
      </nav>

      <div class="flex items-center space-x-8 font-pixel text-base">
        <div class="stat-item">
          <div class="text-[#d82800] font-bold">SCORE</div>
          <div class="text-white font-bold">{score}</div>
        </div>

        <div class="stat-item">
          <div class="flex items-center space-x-2 mt-1">
            <div class="coin-animated"></div>
            <span class="text-[#f8b800] font-bold">×{coins}</span>
          </div>
        </div>

        <div class="stat-item">
          <div class="text-[#00a800] font-bold">WORLD</div>
          <div class="text-white font-bold">{world}</div>
        </div>

        <div class="stat-item">
          <div class="text-[#3cbcfc] font-bold mb-1">LIVES</div>
          <div class="flex items-center justify-center space-x-1">
            {
              Array.from({ length: lives }).map(() => (
                <div class="mario-life" />
              ))
            }
          </div>
        </div>

        <div class="stat-item">
          <div class="text-[#f8b800] font-bold">TIME</div>
          <div class="text-white font-bold">{time}</div>
        </div>
      </div>
    </div>

    <nav
      id="mobile-menu"
      class="md:hidden hidden mt-4 pt-4 border-t-4 border-dashed border-gray-700"
    >
      <div class="flex flex-col space-y-2 font-pixel">
        <a href="/" class="nav-link-mobile">HOME</a>
        <a href="/gallery" class="nav-link-mobile">GALLERY</a>
        <a href="/about" class="nav-link-mobile">ABOUT</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .font-pixel {
    font-family: "Silkscreen", sans-serif;
  }

  .pixel-text {
    text-shadow: 4px 4px 0px #000;
  }

  .coin-animated {
    width: 12px;
    height: 20px;
    background: #f8b800;
    box-shadow:
      -4px 0 0 #000,
      4px 0 0 #000,
      0 -4px 0 #000,
      0 4px 0 #000,
      inset -2px -2px 0 #b87800,
      inset 2px 2px 0 #fff;
    animation: coin-spin 0.8s steps(4) infinite;
  }

  .coin-small {
    width: 8px;
    height: 14px;
    background: #f8b800;
    box-shadow:
      -2px 0 0 #000,
      2px 0 0 #000,
      0 -2px 0 #000,
      0 2px 0 #000,
      inset -1px -1px 0 #b87800;
    animation: coin-spin 0.8s steps(4) infinite;
  }

  @keyframes coin-spin {
    0%,
    100% {
      transform: scaleX(1);
    }
    50% {
      transform: scaleX(0.2);
      background: #b87800;
    }
  }

  .mario-hat {
    width: 24px;
    height: 16px;
    background: #d82800;
    position: relative;
    box-shadow:
      -4px 4px 0 #000,
      4px 4px 0 #000,
      0 -4px 0 #000,
      0 4px 0 #000,
      inset 4px 4px 0 #fff;
  }

  .mario-hat::after {
    content: "";
    position: absolute;
    bottom: -4px;
    right: -6px;
    width: 12px;
    height: 4px;
    background: #d82800;
    box-shadow:
      2px 2px 0 #000,
      0 -2px 0 #000;
  }

  .mario-life {
    width: 12px;
    height: 12px;
    background: #d82800;
    box-shadow:
      -2px 0 0 #000,
      2px 0 0 #000,
      0 -2px 0 #000,
      0 2px 0 #000;
    position: relative;
  }

  .mario-life::after {
    content: "";
    position: absolute;
    top: 2px;
    left: 2px;
    width: 4px;
    height: 4px;
    background: #fff;
  }

  .stat-item {
    text-align: center;
    min-width: 80px;
  }

  .nav-link {
    color: white;
    text-decoration: none;
    padding: 6px 12px;
    border: 4px solid transparent;
    box-sizing: border-box;
  }

  .nav-link:hover {
    color: #f8b800;
    border-color: #f8b800;
    background: #111;
    transform: translateY(-4px);
  }

  .nav-link-mobile {
    color: white;
    text-decoration: none;
    padding: 8px;
    border: 2px solid transparent;
  }

  .nav-link-mobile:hover {
    color: #f8b800;
    background: #111;
    border-color: #f8b800;
  }

  .image-render-pixel {
    image-rendering: pixelated;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");

    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
      });
    }
  });
</script>
