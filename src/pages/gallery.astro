---
import Layout from "../layouts/Layout.astro";
import LevelCard from "../components/gallery/LevelCard.astro";
import FeaturedWorld from "../components/gallery/FeaturedWorld.astro";
import GalleryStats from "../components/gallery/GalleryStats.astro";
import {
  galleryItems,
  getTypeStyle,
  getGalleryStats,
  getDifficultyColor,
} from "../data/galleryData";

const stats = getGalleryStats();
const selectedItem = galleryItems[0];

const itemsPerPage = 12;
const displayedItems = galleryItems.slice(0, itemsPerPage);
---

<Layout
  title="Mario Gallery"
  score={234750}
  coins={57}
  world="GALLERY"
  lives={3}
  time={999}
>
  <main class="mario-bg min-h-screen pt-4">
    <div class="container mx-auto px-4 py-8">
      <div class="text-center mb-8">
        <h1 class="font-pixel text-4xl md:text-6xl text-white pixel-text mb-4">
          🎮 MARIO GALLERY
        </h1>
        <div
          class="inline-block bg-mario-red text-white px-6 py-2 font-pixel text-lg pixel-text"
        >
          SELECT YOUR WORLD
        </div>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-8"
      >
        {
          displayedItems.map((item) => (
            <LevelCard
              item={item}
              getDifficultyColor={getDifficultyColor}
              getTypeStyle={getTypeStyle}
            />
          ))
        }
      </div>

      <FeaturedWorld
        item={selectedItem}
        getDifficultyColor={getDifficultyColor}
      />

      <GalleryStats stats={stats} />
    </div>
  </main>
</Layout>

<style>
  .pixel-text {
    text-shadow: 2px 2px 0px rgba(0, 0, 0, 0.8);
  }
</style>
